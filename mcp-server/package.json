{
  "name": "isracorp-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the Israeli Companies Registrar (ICA)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "devstart": "tsc --watch & nodemon dist/server.js",
    "start": "node dist/server.js",
    "test": "jest --testPathPattern=test/(?!integration)",
    "test:integration": "ICA_INTEGRATION_TEST=true jest --testPathPattern=integration"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.10.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "node-fetch": "^2.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/node-fetch": "^2.6.11",
    "jest": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.0"
  }
}
