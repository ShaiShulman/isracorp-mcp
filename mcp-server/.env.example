# Lookup method: json (API JSON endpoint), scraper (HTML scraper), or both (default: both)
# json   — use the primary ICA JSON API only
# scraper — use the HTML scraper only
# both   — try JSON first, fall back to scraper on empty/error (default behaviour)
ICA_LOOKUP_METHOD=both

# ICA API timeout in milliseconds (default: 10000)
ICA_REQUEST_TIMEOUT_MS=10000

# Number of retries before falling back to scraper (default: 2)
ICA_MAX_RETRIES=2

# Form body encoding for Hebrew names: utf8 or windows1255 (default: utf8)
# Switch to windows1255 if searches return empty results for known Hebrew names
ICA_ENCODING=utf8
